{
  "name": "zalem",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "lucide-react": "^1.6.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "convex": "^1.34.0",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.2.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F @zalem/backend dev",
    "dev:setup": "turbo -F @zalem/backend dev:setup",
    "lint": "oxlint",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "check": "oxlint && oxfmt --check",
    "ci": "bun run check && bun run check-types",
    "thesis:build": "cd thesis && latexmk",
    "thesis:watch": "cd thesis && latexmk -pvc",
    "thesis:clean": "cd thesis && latexmk -c",
    "thesis:diagrams": "mkdir -p thesis/figures && for f in thesis/diagrams/*.mmd; do [ -f \"$f\" ] || continue; out=thesis/figures/$(basename \"$f\" .mmd).pdf; echo \"rendering $f -> $out\"; bunx mmdc -i \"$f\" -o \"$out\" -b transparent --pdfFit -c thesis/diagrams/mermaid-config.json; done"
  },
  "dependencies": {
    "@zalem/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.14.0",
    "@types/bun": "^1.3.13",
    "@zalem/config": "workspace:*",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "turbo": "^2.8.20",
    "typescript": "^6"
  },
  "packageManager": "bun@1.3.10"
}
